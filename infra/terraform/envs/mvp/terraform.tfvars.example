aws_region     = "ap-northeast-2"
project_name   = "llmenhance"
environment    = "mvp"
instance_type  = "t3.large"
root_volume_gb = 100
repo_url       = "https://github.com/ASAC-data-engineer-2-team5/llmenhance.git"
repo_ref       = "main"

# Temporary MVP demo exposure. Prefer a trusted IP range such as
# ["203.0.113.10/32"] instead of the whole internet.
streamlit_allowed_cidr_blocks = ["0.0.0.0/0"]
