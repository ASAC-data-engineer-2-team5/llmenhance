TEAM_ENV_PROFILE=local-ollama
OLLAMA_BASE_URL=http://:11434
LLM_MODEL=qwen3:4b-instruct
EMBEDDING_MODEL=bge-m3


QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=llmenhance_chunks

RETRIEVAL_TOP_K=5
TEMPERATURE=0.2
NUM_CTX=4096
NUM_PREDICT=512

# Vertex Gemini comparison panel
# Host path is mounted read-only into /run/secrets/google-application-credentials.json.
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=./config/google-application-credentials.placeholder.json
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-application-credentials.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_THINKING_BUDGET=0

# Presentation comparison path
BEDROCK_REGION=ap-northeast-2
BEDROCK_MODEL_ID=
BEDROCK_MODEL_LABEL=AWS Bedrock
BEDROCK_MAX_OUTPUT_TOKENS=256
PRESENTATION_TOP_K=3
